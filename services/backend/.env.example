PORT=5000
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/ridershield
JWT_SECRET=your_jwt_secret_here
ML_SERVICE_URL=http://localhost:8000

# OpenWeatherMap — get free key at https://openweathermap.org/api
OPENWEATHER_API_KEY=your_openweathermap_key_here

# WAQI Air Quality API — get free key at https://aqicn.org/data-platform/token/
WAQI_API_KEY=your_waqi_key_here

# NewsAPI — get free key at https://newsapi.org
NEWS_API_KEY=your_newsapi_key_here

# Razorpay — sandbox keys from https://dashboard.razorpay.com
RAZORPAY_KEY_ID=rzp_test_placeholder
RAZORPAY_KEY_SECRET=your_razorpay_secret_here

# Firebase Admin SDK — download from Firebase Console > Project Settings > Service Accounts
FIREBASE_PROJECT_ID=your_firebase_project_id
GOOGLE_APPLICATION_CREDENTIALS=./serviceAccount.json

# HyperTrack — from https://dashboard.hypertrack.com
HYPERTRACK_ACCOUNT_ID=your_hypertrack_account_id
HYPERTRACK_SECRET_KEY=your_hypertrack_secret_key
